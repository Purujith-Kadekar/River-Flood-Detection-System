# ============================================================
# River Flood Detection System — Environment Variables
# ============================================================
#
# Place this file at:  /home/pi/Dashboard/.env
# (same folder as receiver.py and app.py)
#
# NEVER commit this file to Git.
# Add ".env" to your .gitignore.
#
# Get your credentials from: https://app.textbee.dev/dashboard
# 1. Register / log in
# 2. Pair your Android phone (install Textbee app, scan QR)
# 3. Copy the API Key and Device ID shown in the dashboard
#
# ============================================================

# ── Textbee SMS credentials ──────────────────────────────────
TEXTBEE_API_KEY=your_textbee_api_key_here
TEXTBEE_DEVICE_ID=your_textbee_device_id_here

# ── Alert recipients ─────────────────────────────────────────
# Comma-separated E.164 format numbers (include country code)
# Examples: +919876543210,+14155551234
ALERT_PHONE_NUMBERS=+91XXXXXXXXXX

